  "nodes": [
    {
      "id": "n_output",
      "type": "output",
      "label": "Рекомендация",
      "position": {
        "x": 880.0,
        "y": 60.0
      },
      "paramRef": null,
      "refValue": null,
      "deviation": null,
      "operator": null,
      "expression": null,
      "cases": null,
      "action": "recommendation",
      "text": "При безветрии (ветер < 1.5 м/с) и росте PM2.5 формируется экологическая ловушка. ДЛЯ ЖИТЕЛЕЙ: не открывайте окна для проветривания ночью, включите домашние очистители воздуха, отложите пробежки и интенсивные занятия на улице. ПРИ PM2.5 > 35 мкг/м³ (превышение ПДК ВОЗ): ограничьте время на улице, используйте маски FFP2/N95, не проветривайте помещения. ОПЕРАТИВНЫЕ ДЕЙСТВИЯ: 1) Уведомить городскую службу экологии и оперативного штаба. 2) За 6 ± 2 часа направить SMS уязвимым группам (астма, ХОБЛ, дети, пожилые). 3) При подтверждённом ПДК объявить режим НМУ (неблагоприятные метеоусловия), выпустить предписания предприятиям на снижение выбросов 15–20%. 4) Задействовать систему экстренного оповещения населения, информировать школы и детские сады.",
      "priority": 1,
      "constraintRef": null,
      "unit": null,
      "sensorType": null,
      "sensorSubtype": null,
      "bindsTo": null,
      "externalId": null
    },
