@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:NsuCampusSituationalCenterShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [ sh:path :name ; sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path :date ; sh:datatype xsd:date ; sh:minCount 1 ] ;

    sh:property [
        sh:path         :platformUptime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 99.0 ;
        sh:maxInclusive 100.0 ;
        sh:message      "Доступность интеграционной платформы за месяц"@ru
    ] ;
    sh:property [
        sh:path         :platformUptimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 50.0
    ] ;

    sh:property [
        sh:path         :sensorDataLatency ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 300.0 ;
        sh:message      "Задержка данных от инженерных датчиков до СЦ"@ru
    ] ;
    sh:property [
        sh:path         :sensorDataLatencyDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 150.0
    ] ;

    sh:property [
        sh:path         :securityEventReactionTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 30.0 ;
        sh:message      "Время реакции на инцидент уровня critical"@ru
    ] ;
    sh:property [
        sh:path         :securityEventReactionTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 15.0
    ] ;

    sh:property [
        sh:path         :subsystemsCoverage ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 80.0 ;
        sh:maxInclusive 100.0 ;
        sh:message      "Покрытие подсистем интеграционной платформой"@ru
    ] ;
    sh:property [
        sh:path         :subsystemsCoverageDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 50.0
    ] ;

    sh:property [
        sh:path         :simultaneousEventCapacity ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 500.0 ;
        sh:message      "Одновременных событий в обработке"@ru
    ] ;
    sh:property [
        sh:path         :simultaneousEventCapacityDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 250.0
    ] ;

    sh:property [
        sh:path         :operatorShiftSize ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 10.0 ;
        sh:message      "Размер дежурной смены СЦ"@ru
    ] ;
    sh:property [
        sh:path         :operatorShiftSizeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 5.0
    ] .
