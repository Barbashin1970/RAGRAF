@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:KoltsovoEddsCall112Shape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [
        sh:path     :name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message  "Регламент должен содержать имя"@ru
    ] ;
    sh:property [
        sh:path     :date ;
        sh:datatype xsd:date ;
        sh:minCount 1
    ] ;

    sh:property [
        sh:path         :answerTimeSeconds ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.5 ;
        sh:maxInclusive 30.0 ;
        sh:message      "Время ответа оператора 112, секунды"@ru
    ] ;
    sh:property [
        sh:path         :answerTimeSecondsDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 10.0
    ] ;

    sh:property [
        sh:path         :handlingTimeSeconds ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  10.0 ;
        sh:maxInclusive 600.0 ;
        sh:message      "Длительность приёма вызова оператором, секунды"@ru
    ] ;
    sh:property [
        sh:path         :handlingTimeSecondsDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 180.0
    ] ;

    sh:property [
        sh:path         :dispatchTimeMinutes ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.1 ;
        sh:maxInclusive 15.0 ;
        sh:message      "Время передачи карточки в профильную ДДС, минуты"@ru
    ] ;
    sh:property [
        sh:path         :dispatchTimeMinutesDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive  5.0
    ] ;

    sh:property [
        sh:path         :recordRetentionDays ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive    1.0 ;
        sh:maxInclusive 1825.0 ;
        sh:message      "Срок хранения голосовой записи переговоров, сутки"@ru
    ] ;
    sh:property [
        sh:path         :recordRetentionDaysDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive   0.0 ;
        sh:maxInclusive 365.0
    ] ;

    sh:property [
        sh:path         :operatorsOnDuty ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  1.0 ;
        sh:maxInclusive 10.0 ;
        sh:message      "Норматив операторов 112 в смене"@ru
    ] ;
    sh:property [
        sh:path         :operatorsOnDutyDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive  5.0
    ] .
