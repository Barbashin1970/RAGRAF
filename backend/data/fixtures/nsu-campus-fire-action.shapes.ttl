@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:NsuCampusFireActionShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [ sh:path :name ; sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path :date ; sh:datatype xsd:date ; sh:minCount 1 ] ;

    sh:property [
        sh:path         :notificationTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 180.0 ;
        sh:message      "Время сообщения о пожаре на 01/101/112 от обнаружения"@ru
    ] ;
    sh:property [
        sh:path         :notificationTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 150.0
    ] ;

    sh:property [
        sh:path         :smokeDetectionLatency ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 300.0 ;
        sh:message      "Задержка детектора дыма до сигнала на пульт"@ru
    ] ;
    sh:property [
        sh:path         :smokeDetectionLatencyDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 150.0
    ] ;

    sh:property [
        sh:path         :evacuationTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 2.0 ;
        sh:maxInclusive 15.0 ;
        sh:message      "Время эвакуации из здания по нормативу"@ru
    ] ;
    sh:property [
        sh:path         :evacuationTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 10.0
    ] ;

    sh:property [
        sh:path         :fireBrigadeArrival ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 20.0 ;
        sh:message      "Прибытие пожарной службы (норматив МЧС)"@ru
    ] ;
    sh:property [
        sh:path         :fireBrigadeArrivalDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 15.0
    ] ;

    sh:property [
        sh:path         :evacuationMapsCount ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 2.0 ;
        sh:maxInclusive 10.0 ;
        sh:message      "Схем эвакуации на этаже"@ru
    ] ;
    sh:property [
        sh:path         :evacuationMapsCountDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 5.0
    ] ;

    sh:property [
        sh:path         :supervisorNotificationTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 30.0 ;
        sh:message      "Сообщение руководителю подразделения о пожаре"@ru
    ] ;
    sh:property [
        sh:path         :supervisorNotificationTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 15.0
    ] .
