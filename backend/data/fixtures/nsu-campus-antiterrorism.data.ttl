@prefix :     <http://regulations.local/ontology#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Регламент антитеррористической защищённости кампуса НГУ
# Роль: Служба ГО и ЧС / Заместитель руководителя по безопасности
# Источник: Стандарт Минобрнауки, разд. II п. 23 + ПП РФ № 1006 от 02.08.2019.

:Regulation a owl:Class .

:name           a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:string .
:date           a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:date .
:recommendation a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:string .

:massGuardCoverage          a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:massGuardCoverageDeviation a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:drillsPerYear          a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:drillsPerYearDeviation a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:emergencyNotificationTime          a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:emergencyNotificationTimeDeviation a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:notificationSystemChecks          a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:notificationSystemChecksDeviation a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:responseTeamArrival          a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:responseTeamArrivalDeviation a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:perimeterIncidentReports          a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .
:perimeterIncidentReportsDeviation a owl:DatatypeProperty ; rdfs:domain :Regulation ; rdfs:range xsd:decimal .

:NsuCampusAntiterrorismRegulation
    a                      :Regulation ;
    :name                  "Регламент антитеррористической защищённости кампуса НГУ" ;
    :date                  "2024-02-28"^^xsd:date ;
    :massGuardCoverage              100.0 ;
    :massGuardCoverageDeviation     0.0 ;
    :drillsPerYear              4.0 ;
    :drillsPerYearDeviation     1.0 ;
    :emergencyNotificationTime              3.0 ;
    :emergencyNotificationTimeDeviation     2.0 ;
    :notificationSystemChecks              2.0 ;
    :notificationSystemChecksDeviation     1.0 ;
    :responseTeamArrival              4.0 ;
    :responseTeamArrivalDeviation     2.0 ;
    :perimeterIncidentReports              0.0 ;
    :perimeterIncidentReportsDeviation     2.0 ;
    :recommendation        "Регламент антитеррористической защищённости кампуса НГУ (разд. II п. 23 Стандарта 28.02.2024 + Постановление Правительства РФ от 02.08.2019 № 1006 «Об утверждении требований к АТЗ»): 1. ПЕРИМЕТР — 100% покрытие охраной зон массового пребывания (учебные корпуса, библиотека, ФОК, общежития, МФК). СКД + видеонаблюдение с распознаванием лиц. 2. ТРЕВОГА — автоматическое оповещение через РАСЦО за 5 ± 2 минут. Прибытие группы быстрого реагирования ≤ 5 минут. 3. УЧЕНИЯ — не менее 4 в год по эвакуации; не менее 2 проверок систем оповещения в месяц. 4. ОПЕРШТАБ — сбор ≤ 30 минут (аналог koltsovo-edds-mode-escalation). Состав: ректор, заместитель по безопасности, начальник СЦ, представитель ФСБ/МВД. 5. ВЗАИМОДЕЙСТВИЕ С УФСБ/МВД — доклад по протоколу в течение 10 минут с момента подтверждения угрозы. 6. ПОСТАНАЛИЗ — разбор инцидента, корректировка плана учений, доклад ректору и в Минобрнауки." .
