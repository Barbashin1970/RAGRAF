@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:KoltsovoEddsAdpiMonitoringShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [
        sh:path     :name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message  "Регламент должен содержать имя"@ru
    ] ;
    sh:property [
        sh:path     :date ;
        sh:datatype xsd:date ;
        sh:minCount 1
    ] ;

    sh:property [
        sh:path         :alarmDeliverySeconds ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  1.0 ;
        sh:maxInclusive 120.0 ;
        sh:message      "Время доставки тревоги АДПИ на АРМ ЕДДС, с"@ru
    ] ;
    sh:property [
        sh:path         :alarmDeliverySecondsDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 30.0
    ] ;

    sh:property [
        sh:path         :operatorConfirmMinutes ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.5 ;
        sh:maxInclusive 30.0 ;
        sh:message      "Окно подтверждения оператором, мин"@ru
    ] ;
    sh:property [
        sh:path         :operatorConfirmMinutesDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 10.0
    ] ;

    sh:property [
        sh:path         :fireDispatchMinutes ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.1 ;
        sh:maxInclusive 15.0 ;
        sh:message      "Время передачи в пожарную ДДС «01», мин"@ru
    ] ;
    sh:property [
        sh:path         :fireDispatchMinutesDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive  5.0
    ] ;

    sh:property [
        sh:path         :devicesPerWorkstation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive   10.0 ;
        sh:maxInclusive 5000.0 ;
        sh:message      "Максимум устройств АДПИ на одно АРМ, шт."@ru
    ] ;
    sh:property [
        sh:path         :devicesPerWorkstationDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive    0.0 ;
        sh:maxInclusive 2000.0
    ] ;

    sh:property [
        sh:path         :falseAlarmRatePercent ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive   0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message      "Допустимая доля ложных срабатываний, %"@ru
    ] ;
    sh:property [
        sh:path         :falseAlarmRatePercentDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 30.0
    ] ;

    sh:property [
        sh:path         :lowBatteryThresholdPercent ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive   1.0 ;
        sh:maxInclusive  90.0 ;
        sh:message      "Порог низкого заряда батареи для уведомления, %"@ru
    ] ;
    sh:property [
        sh:path         :lowBatteryThresholdPercentDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 30.0
    ] .
