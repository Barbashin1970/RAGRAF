@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:HeatInletBreachShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [ sh:path :name ; sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path :date ; sh:datatype xsd:date   ; sh:minCount 1 ] ;

    sh:property [
        sh:path         :inletPressure ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 25.0 ;
        sh:message      "Давление в тепловом узле, атм"@ru
    ] ;
    sh:property [
        sh:path         :inletPressureDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 5.0
    ] ;

    sh:property [
        sh:path         :inletTemperature ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive   0.0 ;
        sh:maxInclusive 150.0 ;
        sh:message      "Температура подачи, °C"@ru
    ] ;
    sh:property [
        sh:path         :inletTemperatureDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 30.0
    ] ;

    sh:property [
        sh:path         :pressureFallRate ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive  5.0 ;
        sh:message      "Скорость падения давления, атм/мин"@ru
    ] ;
    sh:property [
        sh:path         :pressureFallRateDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 2.0
    ] ;

    sh:property [
        sh:path         :walkerConfirmTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  1.0 ;
        sh:maxInclusive 30.0 ;
        sh:message      "Время до подтверждения обходчиком, мин"@ru
    ] ;
    sh:property [
        sh:path         :walkerConfirmTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 10.0
    ] ;

    sh:property [
        sh:path         :medicalAlertWindow ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  1.0 ;
        sh:maxInclusive 60.0 ;
        sh:message      "Окно оповещения медблока, мин"@ru
    ] ;
    sh:property [
        sh:path         :medicalAlertWindowDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 15.0
    ] .
