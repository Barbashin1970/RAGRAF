@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:NsuCampusAntiterrorismShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [ sh:path :name ; sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path :date ; sh:datatype xsd:date ; sh:minCount 1 ] ;

    sh:property [
        sh:path         :massGuardCoverage ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 95.0 ;
        sh:maxInclusive 100.0 ;
        sh:message      "Покрытие охраной зон массового пребывания"@ru
    ] ;
    sh:property [
        sh:path         :massGuardCoverageDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 50.0
    ] ;

    sh:property [
        sh:path         :drillsPerYear ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 2.0 ;
        sh:maxInclusive 12.0 ;
        sh:message      "Учений по эвакуации в год"@ru
    ] ;
    sh:property [
        sh:path         :drillsPerYearDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 6.0
    ] ;

    sh:property [
        sh:path         :emergencyNotificationTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 15.0 ;
        sh:message      "Время оповещения при ЧС"@ru
    ] ;
    sh:property [
        sh:path         :emergencyNotificationTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 10.0
    ] ;

    sh:property [
        sh:path         :notificationSystemChecks ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 8.0 ;
        sh:message      "Проверок систем оповещения/мес"@ru
    ] ;
    sh:property [
        sh:path         :notificationSystemChecksDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 5.0
    ] ;

    sh:property [
        sh:path         :responseTeamArrival ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 15.0 ;
        sh:message      "Время прибытия группы быстрого реагирования"@ru
    ] ;
    sh:property [
        sh:path         :responseTeamArrivalDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 10.0
    ] ;

    sh:property [
        sh:path         :perimeterIncidentReports ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 50.0 ;
        sh:message      "Инцидентов периметра в месяц"@ru
    ] ;
    sh:property [
        sh:path         :perimeterIncidentReportsDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 25.0
    ] .
