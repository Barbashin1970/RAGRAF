@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:NsuCampusDormitoryStandardShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [ sh:path :name ; sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path :date ; sh:datatype xsd:date ; sh:minCount 1 ] ;

    sh:property [
        sh:path         :areaPerStudent ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 20.0 ;
        sh:maxInclusive 50.0 ;
        sh:message      "Общая площадь здания на одного студента"@ru
    ] ;
    sh:property [
        sh:path         :areaPerStudentDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 25.0
    ] ;

    sh:property [
        sh:path         :studentsPerRoom ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 2.0 ;
        sh:message      "Человек в жилой комнате"@ru
    ] ;
    sh:property [
        sh:path         :studentsPerRoomDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 2.5
    ] ;

    sh:property [
        sh:path         :socketsPerPerson ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 6.0 ;
        sh:maxInclusive 12.0 ;
        sh:message      "Розеток на чел в блоке"@ru
    ] ;
    sh:property [
        sh:path         :socketsPerPersonDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 6.0
    ] ;

    sh:property [
        sh:path         :userSatisfaction ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 75.0 ;
        sh:maxInclusive 100.0 ;
        sh:message      "Уровень удовлетворённости проживанием"@ru
    ] ;
    sh:property [
        sh:path         :userSatisfactionDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 50.0
    ] ;

    sh:property [
        sh:path         :maintenanceRequestTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 48.0 ;
        sh:message      "Время реакции на заявку на ремонт"@ru
    ] ;
    sh:property [
        sh:path         :maintenanceRequestTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 30.0
    ] ;

    sh:property [
        sh:path         :bikeStorageCapacity ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 10.0 ;
        sh:maxInclusive 30.0 ;
        sh:message      "Мест для велосипедов"@ru
    ] ;
    sh:property [
        sh:path         :bikeStorageCapacityDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 15.0
    ] .
