@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:NsuCampusMultifunctionalShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [ sh:path :name ; sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path :date ; sh:datatype xsd:date ; sh:minCount 1 ] ;

    sh:property [
        sh:path         :coworking24h ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 1.0 ;
        sh:maxInclusive 1.0 ;
        sh:message      "Коворкинг 24/7"@ru
    ] ;
    sh:property [
        sh:path         :coworking24hDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 0.5
    ] ;

    sh:property [
        sh:path         :concertHallEventsMonthly ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 5.0 ;
        sh:maxInclusive 50.0 ;
        sh:message      "Мероприятий в концертном зале/мес"@ru
    ] ;
    sh:property [
        sh:path         :concertHallEventsMonthlyDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 25.0
    ] ;

    sh:property [
        sh:path         :mfcSatisfaction ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 75.0 ;
        sh:maxInclusive 100.0 ;
        sh:message      "Удовлетворённость качеством услуг МФК"@ru
    ] ;
    sh:property [
        sh:path         :mfcSatisfactionDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 50.0
    ] ;

    sh:property [
        sh:path         :libraryDigitalRequestsDaily ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 50.0 ;
        sh:maxInclusive 1000.0 ;
        sh:message      "Обращений к цифровой библиотеке/сутки"@ru
    ] ;
    sh:property [
        sh:path         :libraryDigitalRequestsDailyDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 500.0
    ] ;

    sh:property [
        sh:path         :bookingDeskLatency ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 300.0 ;
        sh:message      "Время бронирования через цифровой сервис"@ru
    ] ;
    sh:property [
        sh:path         :bookingDeskLatencyDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 150.0
    ] ;

    sh:property [
        sh:path         :itResponseTime ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 60.0 ;
        sh:message      "Время выезда ИТ-инженера при отказе оборудования"@ru
    ] ;
    sh:property [
        sh:path         :itResponseTimeDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 30.0
    ] .
