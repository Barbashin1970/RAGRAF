@prefix :    <http://regulations.local/ontology#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:KoltsovoEddsCuksReportShape
    a sh:NodeShape ;
    sh:targetClass :Regulation ;

    sh:property [
        sh:path     :name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message  "Регламент должен содержать имя"@ru
    ] ;
    sh:property [
        sh:path     :date ;
        sh:datatype xsd:date ;
        sh:minCount 1
    ] ;

    sh:property [
        sh:path         :verbalReportMinutes ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.5 ;
        sh:maxInclusive 30.0 ;
        sh:message      "Время до устного доклада в ЦУКС, мин"@ru
    ] ;
    sh:property [
        sh:path         :verbalReportMinutesDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 10.0
    ] ;

    sh:property [
        sh:path         :formalReportMinutes ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive   5.0 ;
        sh:maxInclusive 120.0 ;
        sh:message      "Время до формализованного донесения (1ЧС/2ЧС/4ЧС), мин"@ru
    ] ;
    sh:property [
        sh:path         :formalReportMinutesDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 30.0
    ] ;

    sh:property [
        sh:path         :affectedPeopleThreshold ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive    1.0 ;
        sh:maxInclusive 1000.0 ;
        sh:message      "Порог числа пострадавших для эскалации, чел."@ru
    ] ;
    sh:property [
        sh:path         :affectedPeopleThresholdDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive   0.0 ;
        sh:maxInclusive 100.0
    ] ;

    sh:property [
        sh:path         :damageThresholdMillionRub ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive    0.1 ;
        sh:maxInclusive 5000.0 ;
        sh:message      "Порог материального ущерба для эскалации, млн ₽"@ru
    ] ;
    sh:property [
        sh:path         :damageThresholdMillionRubDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive 500.0
    ] ;

    sh:property [
        sh:path         :reportRefreshHours ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.25 ;
        sh:maxInclusive 24.0 ;
        sh:message      "Частота повторных докладов в ЦУКС, ч"@ru
    ] ;
    sh:property [
        sh:path         :reportRefreshHoursDeviation ;
        sh:datatype     xsd:decimal ;
        sh:minCount     1 ;
        sh:minInclusive  0.0 ;
        sh:maxInclusive  6.0
    ] .
