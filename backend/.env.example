# Upstream Regulation Management API
REGULATION_API_URL=http://109.202.1.153:8958
REGULATION_API_TIMEOUT=15

# true  — отдавать данные только из backend/data/fixtures/ (Rules-Management.pdf образец)
# false — пробовать upstream, при недоступности падать на фикстуру
USE_FIXTURES=true

# Когда true — после сохранения через PUT /regulations/{id} также пушим Turtle в upstream `/data`.
# Используется когда есть реальный Sigma upstream и нужно публиковать туда правки.
WRITEBACK_UPSTREAM=false

# RAGU (optional, only used when graph_ragu installed)
RAGU_ENABLED=false
RAGU_STORAGE_FOLDER=./data/ragu_store
RAGU_LLM_MODEL=mistralai/mistral-medium-3
RAGU_EMBED_MODEL=emb-qwen/qwen3-embedding-8b
OPENAI_BASE_URL=
OPENAI_API_KEY=

# CORS — frontend dev origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage for flow snapshots
DATA_DIR=./data
