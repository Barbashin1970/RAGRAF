# Опциональный upstream Regulation Management API.
# История: контракт /api/v1/regulations/{id}/{data,shapes} взят как РЕФЕРЕНС
# с прототипа Sigma. RAGRAF самодостаточен: source of truth — локальный DuckDB
# (backend/data/regulations.duckdb), сидится из backend/data/fixtures/.
# На проде этот URL НЕ используется, переменные ниже включают round-trip
# для тех, кому он реально нужен.
REGULATION_API_URL=http://109.202.1.153:8958
REGULATION_API_TIMEOUT=15

# true  — дефолт. Регламенты читаются ТОЛЬКО локально (DuckDB store + фикстуры).
# false — пробовать опциональный upstream, при недоступности падать на фикстуру.
USE_FIXTURES=true

# Когда true — после сохранения через PUT /regulations/{id} дополнительно пушим
# Turtle в опциональный upstream `/data`. Дефолт — false (запись только в DuckDB).
WRITEBACK_UPSTREAM=false

# RAGU (optional, only used when graph_ragu installed)
RAGU_ENABLED=false
RAGU_STORAGE_FOLDER=./data/ragu_store
RAGU_LLM_MODEL=mistralai/mistral-medium-3
RAGU_EMBED_MODEL=emb-qwen/qwen3-embedding-8b
OPENAI_BASE_URL=
OPENAI_API_KEY=

# CORS — frontend dev origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage for flow snapshots
DATA_DIR=./data
